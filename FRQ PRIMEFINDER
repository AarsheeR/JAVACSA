package javaPack;

public class PrimeFinder {
	/** Returns the number of prime numbers between lower and upper inclusive * Precondition: 0 < lower <= upper 
	*/ 
	public int primesBetween(int lower, int upper) 
	{
		int countprime = 0;
		for (int i = 0; i <= upper-lower; i++){
			if (isPrime(lower + i)){
				countprime++;
			}
		}
		return countprime;

	} 
	/** Returns the difference between num and the closest prime number which * is greater than or equal to num 
	* Precondition: num is positive 
	*/ 
	public int gapToNextPrime(int num) 
	{
		int difference = 0;
		if (isPrime(num)){
			return difference;
		}
		else {
			int numplus = num + 1;
			while (!isPrime(numplus)) {
				numplus++;
			}
		difference = numplus - num;
		return difference;
	}
	}

	/** Returns true if the integer n is a prime number 
	* Precondition: n is positive 
	*/ 
	public boolean isPrime(int n) 
	{
		if (n != 2) {
			for (int i = 2; i < n; i++) {
				if (n % i == 0) {
					return false;
				}
			}
			return true;
		}
		return true;
	} 
}
